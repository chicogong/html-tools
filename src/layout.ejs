<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title><%= title %> - WebUtils</title>

    <!-- SEO Meta Tags -->
    <meta name="description" content="<%= description %>" />
    <meta name="keywords" content="<%= keywords %>" />
    <meta name="author" content="WebUtils" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://tools.realtime-ai.chat/<%= path %>" />

    <!-- Open Graph -->
    <meta property="og:title" content="<%= title %> - WebUtils" />
    <meta property="og:description" content="<%= description %>" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://tools.realtime-ai.chat/<%= path %>" />
    <meta property="og:site_name" content="WebUtils" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:image" content="https://tools.realtime-ai.chat/social-preview.png" />
    <meta property="og:image:width" content="1280" />
    <meta property="og:image:height" content="640" />
    <meta property="og:image:type" content="image/png" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="<%= title %> - WebUtils" />
    <meta name="twitter:description" content="<%= description %>" />
    <meta name="twitter:image" content="https://tools.realtime-ai.chat/social-preview.png" />

    <!-- Favicon & PWA -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#0a0a0f" />
    <link rel="manifest" href="/manifest.json" />

    <script type="application/ld+json">
      <%- JSON.stringify(breadcrumb, null, 2) %>
    </script>
    <script type="application/ld+json">
      <%- JSON.stringify(softwareApp, null, 2) %>
    </script>

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Global Styles -->
    <link rel="stylesheet" href="../../assets/css/tool-base.css" />
    <script src="../../assets/js/tool-chrome.js"></script>
    
    <!-- Tool Specific Styles -->
    <%- styles %>
  </head>
  <body>
    <!-- Header -->
    <header class="site-header">
      <div class="header-left">
        <button id="sidebar-toggle" class="icon-btn" aria-label="Toggle Sidebar">
          <svg viewBox="0 0 24 24" width="24" height="24">
            <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z" fill="currentColor"></path>
          </svg>
        </button>
        <a href="../../index.html" class="logo">
          <span class="logo-icon">🛠️</span>
          <span class="logo-text">WebUtils</span>
        </a>
      </div>
      <div class="header-right">
        <button id="theme-toggle" class="icon-btn" aria-label="Toggle Theme">
          <span class="theme-icon light-icon">☀️</span>
          <span class="theme-icon dark-icon">🌙</span>
        </button>
      </div>
    </header>

    <!-- Sidebar placeholder (populated by tool-chrome.js) -->
    <nav class="sidebar" id="sidebar"></nav>
    <div class="sidebar-overlay" id="sidebar-overlay"></div>

    <main class="tool-main">
      <%- bodyContent %>
    </main>

    <!-- Global Scripts -->
    <script>
      const toggleBtn = document.getElementById("theme-toggle");
      const html = document.documentElement;

      toggleBtn.onclick = () => {
        const current = html.getAttribute("data-theme");
        const newTheme = current === "dark" ? "light" : "dark";
        html.setAttribute("data-theme", newTheme);
        localStorage.setItem("theme", newTheme);
        if (typeof umami !== 'undefined') {
          umami.track('theme_toggle', { theme: newTheme });
        }
      };

      function initTheme() {
        const savedTheme = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const theme = savedTheme || (prefersDark ? "dark" : "light");
        html.setAttribute("data-theme", theme);
      }

      initTheme();
    </script>
    
    <!-- Tool Specific Scripts -->
    <%- scripts %>
  </body>
</html>
